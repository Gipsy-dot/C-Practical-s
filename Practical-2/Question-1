#include <stdio.h>
#include <stdlib.h>

struct Vehical{
    int vno;
    char oname[50];
    char vtype[50];
    int regy;
};
int main(){
    int n,r;

    printf("Enter no. of Vehical: ");
    scanf("%d", &n);

    struct Vehical *ptr;
    ptr = (struct Vehical*)calloc(n , sizeof(struct Vehical));

    if(ptr==NULL){
        printf("No Space\n");
        return 1;
    }
    for(int i=0 ; i<n ; i++){
        printf("\n----------||All Vehical Records %d||--------\n", i+1);
        printf("Enter Vehical no. here:  ");
        scanf("%d", &ptr[i].vno);
        printf("Enter owner name: ");
        scanf("%s", ptr[i].oname);
        printf("Enter Vehical type: ");
        scanf("%s", ptr[i].vtype);
        printf("Enter Vehical registration year: ");
        scanf("%d", &ptr[i].regy);
    }
    printf("\n------||All Records||------\n");
    for(int i = 0; i<n ; i++){
        printf("\n------||Vehical NO. %d-------\n",i+1);
        printf("Vehical no: %d\n",ptr[i].vno);
        printf("Owner name: %s\n", ptr[i].oname);
        printf("Vehical Type: %s\n", ptr[i].vtype);
        printf("Registration Year: %d\n", ptr[i].regy);
    }
    printf("\n------||Search Vehical||-------\n");
     printf("Enter Vehical no here: ");
     scanf("%d",&r);
    for(int i = 0; i<n; i++){
        if(r==ptr[i].vno){
            printf("--||Vehical Found||--\n");
            printf("Vehical no.: %d\n",ptr[i].vno);
            printf("Owner name: %s\n",ptr[i].oname);
            printf("Registration no.: %d\n",ptr[i].regy);
        }
        else{
            printf("gadhi nahi hai tere pass!");
        }
    }
    free (ptr);
    return 0;
}
