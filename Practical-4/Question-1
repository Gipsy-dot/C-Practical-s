#include <iostream>
using namespace std;
class ATM{
    private: 
    int balance = 0;

    public: 

    void deposite(int amount){
        balance = balance + amount;
    };
    void withdraw(int amount){
        if(amount <= balance){
        balance = balance - amount;}
        else{
            cout<<"Insufficent Balance"<<endl;
        }
    };

    void showbalance(){
        cout<<"Balance: "<<balance<<endl;
    }
};

int main (){

    ATM user;

    user.deposite(1000);
    user.withdraw(3000);
    user.showbalance();

    return 0;
}
